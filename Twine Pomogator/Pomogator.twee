<script>
    const today = new Date();
    const formattedDate = today.getFullYear() + "-" +
        String(today.getMonth() + 1).padStart(2, '0') + "-" +
        String(today.getDate()).padStart(2, '0');
    document.getElementById("currentDate").textContent = "due:" + formattedDate;
    
    

    // Форматируем дату для Google Календаря (YYYYMMDD)
    const googleDate = today.getFullYear() + 
        String(today.getMonth() + 1).padStart(2, '0') + 
        String(today.getDate()).padStart(2, '0');

    // Создаем ссылку на событие
    const googleCalendarLink = `https://calendar.google.com/calendar/r/eventedit?dates=${googleDate}/${googleDate}&text=Новое+Событие&details=Описание+события&location=Онлайн`;

    // Вставляем ссылку в элемент #calendarLink
    document.getElementById("calendarLink").innerHTML = `<a href="${googleCalendarLink}" target="_blank">Добавить событие в Google Календарь</a>`;
</script>



